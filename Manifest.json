{
  "manifest_version": 3,
  "name": "FirstOne – Earn Your Scroll Time",
  "version": "1.0.0",
  "description": "Work to earn coins. Spend coins to unlock distracting sites. Gamified focus.",
  "permissions": ["activeTab", "tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.twitch.tv/*",
        "*://*.tiktok.com/*",
        "*://*.discord.com/*",
        "*://*.steampowered.com/*",
        "*://*.steamcommunity.com/*",
        "*://*.pinterest.com/*",
        "*://*.facebook.com/*",
        "*://*.reddit.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
